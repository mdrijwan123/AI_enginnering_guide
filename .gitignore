# ──────────────────────────────────────────────────────────────
#  .gitignore — LLM/AI Engineer Study Plan
#  GitHub standard rules for Python / AI / ML project
# ──────────────────────────────────────────────────────────────

# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd
*.egg
*.egg-info/
dist/
build/
.eggs/
*.whl
pip-log.txt
pip-delete-this-directory.txt

# ── Virtual environments ───────────────────────────────────────
.venv/
venv/
env/
ENV/
.conda/
# Keep environment.yml for reproducibility — uncommenting ignores it:
# environment.yml

# ── Jupyter / IPython ─────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints
profile_default/
ipython_config.py
# Uncommenting ignores all notebooks (remove to track .ipynb files):
# *.ipynb

# ── ML / AI artefacts ─────────────────────────────────────────
# Model weights & checkpoints (too large for git)
*.pt
*.pth
*.ckpt
*.safetensors
*.bin
*.gguf
*.ggml
*.pkl
*.pickle
*.joblib
*.h5
*.hdf5
*.npz
*.npy

# Training runs / experiment tracking
runs/
outputs/
checkpoints/
mlruns/
wandb/
lightning_logs/
.aim/

# ── Graphify pipeline temp artefacts ──────────────────────────
graphify-out/.graphify_python
graphify-out/.graphify_detect.json
graphify-out/.graphify_extract.json
graphify-out/.graphify_ast.json
graphify-out/.graphify_semantic.json
graphify-out/.graphify_analysis.json
graphify-out/.graphify_labels.json
graphify-out/.graphify_cached.json
graphify-out/.graphify_uncached.txt
graphify-out/.graphify_chunk_*.json
graphify-out/.graphify_semantic_new.json
graphify-out/.graphify_transcripts.json
graphify-out/.graphify_manifest.json
graphify-out/.needs_update
graphify-out/_*.py
# Useful outputs — kept in git (remove # to ignore them):
# graphify-out/graph.html
# graphify-out/graph.json
# graphify-out/GRAPH_REPORT.md
# graphify-out/cost.json

# ── Data files ────────────────────────────────────────────────
*.csv
*.tsv
*.parquet
*.feather
*.arrow
data/
datasets/
raw/

# ── Office / proprietary docs ─────────────────────────────────
# The .xlsx and .docx files are currently committed.
# Uncomment below to stop tracking them:
# *.xlsx
# *.xls
# *.docx
# *.doc
# *.pptx

# ── Secrets & credentials ─────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.cert
secrets/
config/secrets.yaml
config/secrets.json
openai_key.txt
anthropic_key.txt
hf_token.txt
*.token

# ── OS artefacts ──────────────────────────────────────────────
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~
.fuse_hidden*
.Trash-*
.nfs*

# ── Editor / IDE ──────────────────────────────────────────────
# VS Code (keep shared settings by uncommenting the exceptions)
.vscode/
# !.vscode/extensions.json
# !.vscode/settings.json

# JetBrains (PyCharm, DataSpell)
.idea/
*.iml
*.iws
*.ipr

# Vim / Emacs
*.swp
*.swo
\#*\#
.#*

# ── Logs & temp files ─────────────────────────────────────────
*.log
*.tmp
*.temp
logs/
tmp/
.cache/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── Docker ────────────────────────────────────────────────────
# Keep Dockerfile and docker-compose.yml — only ignore local overrides:
docker-compose.override.yml

# ── Coverage & testing ────────────────────────────────────────
.coverage
.coverage.*
coverage.xml
htmlcov/
.tox/
nosetests.xml
pytest.xml

# ── Misc ──────────────────────────────────────────────────────
.hypothesis/
.benchmarks/
*.pid
*.seed
